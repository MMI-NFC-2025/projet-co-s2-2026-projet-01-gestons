---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
    image: ImageMetadata;
    alt: string;
    href: string;
    description: string;
}

const { image, alt, href, description } = Astro.props;
---

<div class="flex flex-col gap-3 w-full">
    <p
        class="font-bold font-lato text-base text-gray-900 underline underline-offset-4"
    >
        {description}
        <span class="text-gray-400 text-sm font-bold" aria-hidden="true">→</span
        >
    </p>
    <a
        href={href}
        class="block w-full rounded-2xl overflow-hidden hover:opacity-90 transition-opacity focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--light-green)"
    >
        <Image
            src={image}
            alt={alt}
            class="w-full h-auto object-cover"
            widths={[400, 800]}
            sizes="(max-width: 768px) 100vw, 800px"
            class="border-(--pink) border-2"
        />
    </a>
</div>
