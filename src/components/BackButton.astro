---
interface Props {
    href?: string;
    label?: string;
}
const { href = "/", label = "<- Retour" } = Astro.props;
---

<a
    href={href}
    class="inline-flex items-center gap-1 border-2 border-(--light-green) text-(--green) font-lato font-bold text-sm rounded-xl px-4 py-2 hover:bg-(--light-green) transition-colors focus-visible:outline-2 focus-visible:outline-(--light-green)"
>
    {label}
</a>
