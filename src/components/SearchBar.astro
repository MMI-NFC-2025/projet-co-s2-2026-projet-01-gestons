---
import loupe from "../assets/icon/loupe.svg";

interface Props {
    placeholder?: string;
    class?: string;
}

const {
    placeholder = "Rechercher un mot / une expression...",
    class: className = "",
} = Astro.props;

import PocketBase from "pocketbase";

const pb = new PocketBase("https://gestons.girardin-tarby.fr");

let mots: { id: string; titre: string }[] = [];
try {
    const records = await pb
        .collection("mot")
        .getFullList({ fields: "id,mot_associe", sort: "mot_associe" });
    mots = records.map((r) => ({ id: r.id, titre: r.mot_associe as string }));
} catch (e) {
    console.warn(
        "[SearchBar] Impossible de charger les mots depuis PocketBase :",
        e,
    );
}
---

<div class:list={["relative w-full", className]} id="searchbar-wrapper">
    <input
        id="searchbar-input"
        type="search"
        placeholder={placeholder}
        autocomplete="off"
        class="w-full rounded-full border-2 border-(--pink) bg-white px-5 py-2.5 pr-12 text-sm font-lato text-gray-700 placeholder:text-gray-400 focus:outline-none focus:border-(--light-green) transition-colors"
        aria-label="Rechercher un mot ou une expression"
        aria-autocomplete="list"
        aria-controls="searchbar-suggestions"
    />
    <button
        id="searchbar-btn"
        type="button"
        class="absolute right-3 top-1/2 -translate-y-1/2 p-1 hover:opacity-75 transition-opacity"
        aria-label="Lancer la recherche"
    >
        <img src={loupe.src} alt="" width="22" height="22" aria-hidden="true" />
    </button>
    <ul
        id="searchbar-suggestions"
        role="listbox"
        class="absolute left-0 right-0 top-full mt-1 bg-white border-2 border-(--light-green) rounded-2xl overflow-hidden shadow-lg z-50 hidden"
    >
    </ul>
</div>

<script define:vars={{ mots }}>
    const input = document.getElementById("searchbar-input");
    const btn = document.getElementById("searchbar-btn");
    const list = document.getElementById("searchbar-suggestions");

    function normalize(str) {
        return str
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "");
    }

    function showSuggestions(query) {
        const q = normalize(query.trim());
        list.innerHTML = "";
        if (!q) {
            list.classList.add("hidden");
            return;
        }

        const matches = mots.filter((m) => normalize(m.titre).includes(q));
        if (!matches.length) {
            list.classList.add("hidden");
            return;
        }

        matches.forEach((m) => {
            const li = document.createElement("li");
            li.setAttribute("role", "option");
            li.textContent = m.titre;
            li.className =
                "px-5 py-2.5 text-sm font-lato text-(--green) cursor-pointer hover:bg-(--light-green) hover:text-white transition-colors";
            li.addEventListener("mousedown", (e) => {
                e.preventDefault();
                window.location.href = `/mots/${m.id}`;
            });
            list.appendChild(li);
        });
        list.classList.remove("hidden");
    }

    function navigate() {
        const q = normalize(input.value.trim());
        if (!q) return;
        const match = mots.find((m) => normalize(m.titre) === q);
        if (match) {
            window.location.href = `/mots/${match.id}`;
        } else {
            // Prendre la première suggestion si elle existe
            const first = mots.find((m) => normalize(m.titre).includes(q));
            if (first) window.location.href = `/mots/${first.id}`;
        }
    }

    input.addEventListener("input", () => showSuggestions(input.value));
    input.addEventListener("blur", () =>
        setTimeout(() => list.classList.add("hidden"), 150),
    );
    input.addEventListener("focus", () => showSuggestions(input.value));
    input.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
            list.classList.add("hidden");
            navigate();
        }
        if (e.key === "Escape") {
            list.classList.add("hidden");
        }
    });
    btn.addEventListener("click", () => {
        list.classList.add("hidden");
        navigate();
    });
</script>
