---
import StarProgress from "./StarProgress.astro";

interface Props {
    streakDays?: number;
    level?: number;
    starsProgress?: number;
    totalStars?: number;
}

const {
    streakDays = 5,
    level = 4,
    starsProgress = 3,
    totalStars = 5,
} = Astro.props;
---

<section class="flex flex-col items-center gap-3 w-full px-4">
    <span class="text-8xl leading-none" role="img" aria-label="Flamme de série"
        >🔥</span
    >
    <p class="text-center text-lg font-bold font-lato">
        Série de <span class="text-(--light-green)">{streakDays}</span> jours !!!
    </p>
    <p class="text-center font-lato text-base text-gray-700">
        Continuez comme ça !
    </p>
    <div class="w-full max-w-xs">
        <StarProgress total={totalStars} filled={starsProgress} />
    </div>
    <p class="text-center text-(--light-green) font-bold font-lato text-base">
        Niveau {level} !!!
    </p>
</section>
